rules_version = '2';

// Pravila poslije Etape 6: XP i statistiku mijenja ISKLJUČIVO server
// (Cloud Functions preko Admin SDK-a, koji zaobilazi ova pravila).
service cloud.firestore {
  match /databases/{database}/documents {

    // 'users' dokumenti
    match /users/{userId} {
      // Svaki prijavljen korisnik može čitati profile (za leaderboard/javne profile).
      allow read: if request.auth != null;
      // Kreiranje: samo vlastiti profil, i XP mora krenuti od nule.
      allow create: if request.auth != null && request.auth.uid == userId
                    && request.resource.data.xp == 0;
      // Izmjena: samo vlastiti profil, i SAMO ime/avatar — XP, statistika,
      // taskovi i sve ostalo su rezervisani za server.
      allow update: if request.auth != null && request.auth.uid == userId
                    && request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(['displayName', 'avatar']);
      allow delete: if false;
    }

    // 'questions' — banka pitanja (Modul 3).
    // Čitanje: samo prijavljeni korisnici. Pisanje: NIKO s klijenta —
    // pitanja se uvoze isključivo admin skriptom (scripts/import-questions.js),
    // koja ide preko Admin SDK-a i zaobilazi ova pravila.
    match /questions/{questionId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // 'config' — konfiguracija igre (XP kriva itd., Modul 5).
    // Čitanje za prijavljene; pisanje samo admin skriptom (Admin SDK).
    match /config/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // 'tasks' — definicije dnevnih/sedmičnih/mjesečnih taskova (Modul 6).
    // Čitanje za prijavljene; pisanje samo admin skriptom (Admin SDK).
    match /tasks/{taskId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // 'questionSecrets' — tačni odgovori i objašnjenja (Etapa 6).
    // NIKO s klijenta; čita ih isključivo server (Cloud Functions).
    match /questionSecrets/{questionId} {
      allow read, write: if false;
    }

    // 'quizSessions' — aktivne kviz sesije (Etapa 6). Samo server.
    match /quizSessions/{sessionId} {
      allow read, write: if false;
    }
  }
}
