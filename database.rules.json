{
  "rules": {
    ".read": false,
    ".write": false,
    "leaderboard": {
      "global": {
        ".read": "auth != null",
        ".indexOn": ["xp"],
        "$uid": {
          ".write": "auth != null && auth.uid == $uid"
        }
      },
      "weekly": {
        "$week": {
          ".read": "auth != null",
          ".indexOn": ["xp"],
          "$uid": {
            ".write": "auth != null && auth.uid == $uid"
          }
        }
      }
    }
  }
}
